{
  "npm": {
    "publish": false
  },
  "git": {
    "tagName": "v${version}",
    "commitMessage": "chore(release): v${version}"
  },
  "github": {
    "release": true
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  },
  "hooks": {
    "after:bump": "node scripts/sync-versions.ts ${version}"
  }
}
